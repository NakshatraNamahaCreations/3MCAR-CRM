# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/carworkshop_crm

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins, or * for all)
CLIENT_ORIGIN=http://localhost:5173

# Workshop working hours config (used in attendance/overtime calc)
STANDARD_WORKING_HOURS=8

# Workshop identity (shown on generated quotation / invoice PDFs)
WORKSHOP_NAME=Car Workshop CRM
WORKSHOP_BRAND_TOP=3M
WORKSHOP_BRAND_REST=CAR CARE STUDIO
WORKSHOP_TAGLINE=Premium Automotive Protection
WORKSHOP_ADDRESS=Service Lane, Auto Hub
WORKSHOP_PHONE=
WORKSHOP_EMAIL=
WORKSHOP_GSTIN=
WORKSHOP_PAN=
WORKSHOP_UPI=

# Bank details (shown on quotation PDF)
BANK_NAME=
BANK_ACCOUNT_NO=
BANK_IFSC=

# Payment terms (shown on quotation PDF)
PAYMENT_ADVANCE=50% at booking
PAYMENT_BALANCE=50% on completion
PAYMENT_MODES=Cash / UPI / Card / NEFT
