# ---- Production environment for api.3mcarcarestudios.in ----
# Copy to `.env` on the server and fill in the real secrets.

NODE_ENV=production
# The port your process listens on (put your reverse proxy / Nginx in front of it).
PORT=5003

# MongoDB connection string (Atlas or self-hosted)
MONGO_URI=your-production-mongodb-uri

# Auth
JWT_SECRET=use-a-long-random-secret-here
JWT_EXPIRES_IN=7d

# CORS — the admin frontend origin(s). Comma-separated for multiple.
CLIENT_ORIGIN=https://admin.3mcarcarestudios.in

# Company / branding shown on quotation & invoice PDFs (Settings page overrides these)
WORKSHOP_NAME=3M Car Care
WORKSHOP_ADDRESS=Jayanagar, Bengaluru
WORKSHOP_PHONE=
WORKSHOP_EMAIL=
WORKSHOP_GSTIN=

# First-run admin seed (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@workshop.com
SEED_ADMIN_PASSWORD=Admin@123

STANDARD_WORKING_HOURS=8
